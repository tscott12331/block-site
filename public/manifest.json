{
    "manifest_version": 3,
    "name": "Block Site",
    "version": "0.1",
    "description": "Blocks user added sites",
    "action": {
        "default_popup": "index.html"
    },

    "background": {
        "service_worker": "background.js", 
        "scripts": ["background.js"],
        "type": "module"
    }
}
